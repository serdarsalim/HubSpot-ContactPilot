{
  "manifest_version": 3,
  "name": "ContactPilot",
  "version": "2.0.0",
  "description": "Contact workflow sidecar with WhatsApp links, notes, and email templates.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "ContactPilot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.hubspot.com/*"
      ],
      "js": [
        "shared/messages.js",
        "shared/config.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
