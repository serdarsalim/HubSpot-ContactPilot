{
  "manifest_version": 3,
  "name": "Contact Point",
  "version": "2026.4.15.1",
  "description": "HubSpot contact workflow extension for WhatsApp, notes, and email templates.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.hubspot.com/*",
    "https://web.whatsapp.com/*",
    "https://us.i.posthog.com/*",
    "https://contactpoint.vercel.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Contact Point",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.hubspot.com/*"
      ],
      "js": [
        "shared/messages.js",
        "shared/config.js",
        "vendor/darkreader/darkreader.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
